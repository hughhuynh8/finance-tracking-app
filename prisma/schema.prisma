generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Transaction {
  id          String   @id @default(cuid())
  type        String   // "INCOME" or "EXPENSE"
  amount      Float
  date        DateTime @default(now())
  category    String   // e.g., "Rent", "Groceries", "Subscriptions", "Salary"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PortfolioItem {
  id           String   @id @default(cuid())
  ticker       String   @unique // e.g., "AAPL", "MSFT"
  shares       Float
  averagePrice Float?   // Optional: average purchase price
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Mortgage {
  id               String              @id @default(cuid())
  name             String              // e.g., "CBA Home Loan"
  principal        Float               // original/opening loan balance
  interestRate     Float               // annual nominal rate, percent (e.g. 6.14)
  monthlyRepayment Float               // scheduled monthly repayment, used for payoff projection
  startDate        DateTime            // opening-balance date
  repayments       MortgageRepayment[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model MortgageRepayment {
  id         String   @id @default(cuid())
  mortgageId String
  mortgage   Mortgage @relation(fields: [mortgageId], references: [id], onDelete: Cascade)
  date       DateTime
  amount     Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
